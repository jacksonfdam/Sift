{
  "name": "sift",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first, in-memory HTTP capture viewer (HAR / SAZ / Charles) — DevTools panel + standalone offline page.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @sift/core build",
    "build:extension": "pnpm --filter @sift/extension build",
    "build:standalone": "pnpm --filter @sift/standalone build",
    "dev:standalone": "pnpm --filter @sift/standalone dev",
    "dev:extension": "pnpm --filter @sift/extension dev",
    "test": "pnpm --filter @sift/core test",
    "typecheck": "pnpm -r typecheck",
    "verify:egress": "node scripts/verify-egress.mjs",
    "verify": "pnpm build && pnpm test && pnpm verify:egress"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  },
  "packageManager": "pnpm@9.12.3"
}
